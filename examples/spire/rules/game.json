{
  "rules": [
    {
      "id": "boot-bgm",
      "on": {
        "event": "start"
      },
      "do": [
        {
          "emit": "play-music",
          "data": {
            "sound": "bgm.wav",
            "volume": 0.25
          }
        }
      ]
    },
    {
      "id": "boot-battle",
      "on": {
        "event": "start"
      },
      "do": [
        {
          "call": "start-battle",
          "with": {
            "php": "@hero.Unit.hp",
            "pmax": "@hero.Unit.maxhp",
            "e0hp": "@enemy-0.Unit.hp",
            "e0max": "@enemy-0.Unit.maxhp",
            "e1hp": "@enemy-1.Unit.hp",
            "e1max": "@enemy-1.Unit.maxhp"
          }
        }
      ]
    },
    {
      "id": "play-1",
      "on": {
        "event": "input",
        "filter": {
          "action": "1",
          "phase": "pressed"
        }
      },
      "if": [
        [
          "@battle.Battle.phase",
          "==",
          "player"
        ],
        [
          "@battle.Card.slot",
          "==",
          0
        ]
      ],
      "do": [
        {
          "set": "@battle.Card.slot",
          "to": 1
        },
        {
          "call": "play-card",
          "with": {
            "slot": 1,
            "energy": "@battle.Battle.energy",
            "turn": "@battle.Battle.turn",
            "hand": "@battle.Deck.hand",
            "draw": "@battle.Deck.draw",
            "discard": "@battle.Deck.discard",
            "php": "@hero.Unit.hp",
            "pmax": "@hero.Unit.maxhp",
            "pblock": "@hero.Unit.block",
            "e0hp": "@enemy-0.Unit.hp",
            "e0max": "@enemy-0.Unit.maxhp",
            "e0block": "@enemy-0.Unit.block",
            "e0vuln": "@enemy-0.Unit.vuln",
            "e0ikind": "@enemy-0.Intent.kind",
            "e0ivalue": "@enemy-0.Intent.value",
            "e1hp": "@enemy-1.Unit.hp",
            "e1max": "@enemy-1.Unit.maxhp",
            "e1block": "@enemy-1.Unit.block",
            "e1vuln": "@enemy-1.Unit.vuln",
            "e1ikind": "@enemy-1.Intent.kind",
            "e1ivalue": "@enemy-1.Intent.value"
          }
        }
      ]
    },
    {
      "id": "play-2",
