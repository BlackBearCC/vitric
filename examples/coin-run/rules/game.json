{
  "rules": [
    {
      "id": "move-right-start",
      "on": {
        "event": "input",
        "filter": {
          "action": "right",
          "phase": "pressed"
        }
      },
      "do": [
        {
          "set": "@player.Velocity.x",
          "to": "@player.Speed.value"
        },
        {
          "set": "@player.Anim.clip",
          "to": "walk"
        }
      ]
    },
    {
      "id": "move-right-stop",
      "on": {
        "event": "input",
        "filter": {
          "action": "right",
          "phase": "released"
        }
      },
      "do": [
        {
          "set": "@player.Velocity.x",
          "to": 0
        },
        {
          "set": "@player.Anim.clip",
          "to": "idle"
        }
      ]
    },
    {
      "id": "collect-coin",
      "on": {
        "event": "collision",
        "between": [
          "Player",
          "Coin"
        ]
      },
      "do": [
        {
          "add": "self.Score.value",
          "by": "other.Coin.value"
        },
        {
          "despawn": "other"
        },
        {
          "set": "@hud.Text.content",
          "to": {
            "format": "SCORE {}",
            "args": [
              "self.Score.value"
            ]
          }
        },
        {
          "emit": "coin-collected",
          "data": {
            "who": "self",
            "total": "self.Score.value"
          }
        },
        {
          "emit": "play-sound",
          "data": {
            "sound": "coin.wav"
          }
        }
      ]
    },
    {
      "id": "win-check",
      "on": {
        "event": "coin-collected"
      },
      "if": [
        [
          "@player.Score.value",
          ">=",
          3
        ]
      ],
      "do": [
        {
          "call": "celebrate",
          "with": {
            "score": "@player.Score.value"
          }
        },
        {
          "set": "@player.Velocity.x",
          "to": 0
        },
        {
          "set": "@hud.Text.content",
          "to": "YOU WIN!"
        }
      ]
    }
  ]
}