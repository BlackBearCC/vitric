            "sound": "bgm-menu.wav",
            "volume": 0.3
          }
        }
      ]
    },
    {
      "id": "bgm-battle-1",
      "on": {
        "event": "scene-loaded",
        "filter": {
          "scene": "scenes/battle-1.json"
        }
      },
