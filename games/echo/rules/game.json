          2
        ]
      ],
      "do": [
        {
          "set": "@node-2.Sprite.color",
          "to": "#6f6a7a"
        }
      ]
    },
    {
      "id": "hit-feedback",
      "on": {
        "event": "player-hit"
      },
      "do": [
        {
          "set": "@camera.Shake.amplitude",
          "to": 0.5
        },
        {
          "emit": "play-sound",
          "data": {
            "sound": "hit.wav",
            "volume": 0.8
          }
        }
      ]
    },
    {
      "id": "shade-died-feedback",
      "on": {
        "event": "shade-died"
      },
      "do": [
        {
          "set": "@camera.Shake.amplitude",
          "to": 0.3
        },
        {
          "emit": "play-sound",
          "data": {
            "sound": "die.wav",
            "volume": 0.7
          }
        },
        {
          "call": "burst",
          "with": {
            "x": "event.x",
            "y": "event.y",
            "n": 10
          }
        }
      ]
    },
    {
      "id": "shade-stunned-sound",
      "on": {
        "event": "shade-stunned"
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "stun.wav",
            "volume": 0.6
          }
        }
      ]
    },
    {
      "id": "shade-acted-sound",
      "on": {
        "event": "shade-acted"
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "hiss.wav",
            "volume": 0.3
          }
        }
      ]
    },
    {
      "id": "card-played-sound",
      "on": {
        "event": "card-played"
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "card.wav",
            "volume": 0.6
          }
        }
      ]
    },
    {
      "id": "lamp-placed-sound",
      "on": {
        "event": "card-played",
        "filter": {
          "name": "lamp"
        }
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "lamp.wav",
            "volume": 0.7
          }
        }
      ]
    },
    {
      "id": "card-rejected-sound",
      "on": {
        "event": "card-rejected"
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "reject.wav",
            "volume": 0.5
          }
        }
      ]
    },
    {
      "id": "lamp-devoured-feedback",
      "on": {
        "event": "lamp-devoured"
      },
      "do": [
        {
          "set": "@camera.Shake.amplitude",
          "to": 0.4
        },
        {
          "emit": "play-sound",
          "data": {
            "sound": "devour.wav",
            "volume": 0.8
          }
        }
      ]
    },
    {
      "id": "battle-won-feedback",
      "on": {
        "event": "battle-won"
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "win.wav",
            "volume": 0.8
          }
        },
        {
          "call": "burst",
          "with": {
            "x": 0,
            "y": 0,
            "n": 24
          }
        }
      ]
    },
    {
      "id": "battle-lost-sound",
      "on": {
        "event": "battle-lost"
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "lose.wav",
            "volume": 0.8
          }
        }
      ]
    },
    {
      "id": "bgm-boot",
      "on": {
        "event": "start"
      },
      "do": [
        {
          "emit": "play-music",
          "data": {
            "sound": "bgm-menu.wav",
            "volume": 0.3
          }
        }
      ]
    },
    {
      "id": "bgm-menu",
      "on": {
        "event": "scene-loaded",
        "filter": {
          "scene": "scenes/menu.json"
        }
      },
      "do": [
        {
          "emit": "play-music",
          "data": {
            "sound": "bgm-menu.wav",
            "volume": 0.3
          }
        }
      ]
    },
    {
      "id": "bgm-map",
      "on": {
        "event": "scene-loaded",
        "filter": {
          "scene": "scenes/map.json"
        }
      },
      "do": [
        {
          "emit": "play-music",
          "data": {
            "sound": "bgm-menu.wav",
            "volume": 0.3
          }
        }
      ]
    },
    {
      "id": "bgm-battle-1",
      "on": {
        "event": "scene-loaded",
        "filter": {
          "scene": "scenes/battle-1.json"
        }
      },
      "do": [
        {
          "emit": "play-music",
          "data": {
            "sound": "bgm-battle.wav",
            "volume": 0.3
          }
        }
      ]
    },
    {
      "id": "bgm-battle-2",
      "on": {
        "event": "scene-loaded",
        "filter": {
          "scene": "scenes/battle-2.json"
        }
      },
      "do": [
        {
          "emit": "play-music",
          "data": {
            "sound": "bgm-battle.wav",
            "volume": 0.3
          }
        }
      ]
    },
    {
      "id": "bgm-boss",
      "on": {
        "event": "scene-loaded",
        "filter": {
          "scene": "scenes/boss.json"
        }
      },
      "do": [
        {
          "emit": "play-music",
          "data": {
            "sound": "bgm-battle.wav",
            "volume": 0.3
          }
        }
      ]
    },
    {
      "id": "apply-hint",
      "on": { "event": "sync-hint" },
      "if": [["@hud-hint", "exists"]],
      "do": [
        { "set": "@hud-hint.Text.content", "to": "event.text" }
      ]
    },
    {
      "id": "tut-step-select",
      "on": { "event": "sync-hand" },
      "if": [
        ["@tutor", "exists"],
        ["@tutor.Card.slot", "<", 1],
        ["@ctl.Card.slot", ">=", 1]
      ],
      "do": [
        { "set": "@tutor.Card.slot", "to": 1 }
      ]
    },
    {
      "id": "tut-step-play",
      "on": { "event": "card-played" },
      "if": [
        ["@tutor", "exists"],
        ["@tutor.Card.slot", "<", 2]
      ],
      "do": [
        { "set": "@tutor.Card.slot", "to": 2 }
      ]
    },
    {
      "id": "tut-step-endturn",
      "on": { "event": "sync-hud" },
      "if": [
        ["@tutor", "exists"],
        ["@tutor.Card.slot", "<", 3],
        ["event.oil", "==", "OIL 0"]
      ],
      "do": [
        { "set": "@tutor.Card.slot", "to": 3 }
      ]
    },
    {
      "id": "tut-step-stun",
      "on": { "event": "shade-stunned" },
      "if": [
        ["@tutor", "exists"],
        ["@tutor.Card.slot", "<", 4]
      ],
      "do": [
        { "set": "@tutor.Card.slot", "to": 4 }
      ]
    },
    {
      "id": "tut-step-kill",
      "on": { "event": "shade-died" },
      "if": [
        ["@tutor", "exists"],
        ["@tutor.Card.slot", "<", 5]
      ],
      "do": [
        { "set": "@tutor.Card.slot", "to": 5 }
      ]
    },
    {
      "id": "card-help-clear",
      "on": { "event": "mouse-alt" },
      "if": [
        ["@ctl", "exists"],
        ["@ctl.Shade.hp", "==", 0],
        ["@ctl.Shade.stunned", "==", false]
      ],
      "do": [
        { "set": "@ctl.Cell.cx", "to": 20 }
      ]
    },
    {
      "id": "card-help-slot-1",
      "on": { "event": "mouse-alt", "filter": { "entity": "slot-1" } },
      "if": [
        ["@ctl", "exists"],
        ["@ctl.Shade.hp", "==", 0],
        ["@ctl.Shade.stunned", "==", false]
      ],
      "do": [
        { "set": "@ctl.Cell.cx", "to": 21 }
      ]
    },
    {
      "id": "card-help-slot-2",
      "on": { "event": "mouse-alt", "filter": { "entity": "slot-2" } },
      "if": [
        ["@ctl", "exists"],
        ["@ctl.Shade.hp", "==", 0],
        ["@ctl.Shade.stunned", "==", false]
      ],
      "do": [
        { "set": "@ctl.Cell.cx", "to": 22 }
      ]
    },
    {
      "id": "card-help-slot-3",
      "on": { "event": "mouse-alt", "filter": { "entity": "slot-3" } },
      "if": [
        ["@ctl", "exists"],
        ["@ctl.Shade.hp", "==", 0],
        ["@ctl.Shade.stunned", "==", false]
      ],
      "do": [
        { "set": "@ctl.Cell.cx", "to": 23 }
      ]
    },
    {
      "id": "card-help-slot-4",
      "on": { "event": "mouse-alt", "filter": { "entity": "slot-4" } },
      "if": [
        ["@ctl", "exists"],
        ["@ctl.Shade.hp", "==", 0],
        ["@ctl.Shade.stunned", "==", false]
      ],
      "do": [
        { "set": "@ctl.Cell.cx", "to": 24 }
      ]
    },
    {
      "id": "spawn-progress",
      "on": { "event": "start" },
      "do": [
        {
          "spawn": {
            "name": "progress",
            "components": {
              "Run": { "node": 0, "phase": "player", "turn": 1 },
              "Persist": {}
            }
          }
        }
      ]
    },
    {
      "id": "pause-key",
      "on": { "event": "input", "filter": { "action": "escape", "phase": "pressed" } },
      "if": [["@ctl", "exists"]],
      "do": [
        { "set": "@ctl.Cell.cx", "to": 3 },
        { "emit": "play-sound", "data": { "sound": "click.wav", "volume": 0.4 } }
      ]
    },
    {
      "id": "pause-resume-key",
      "on": { "event": "input", "filter": { "action": "r", "phase": "pressed" } },
      "if": [
        ["@ctl", "exists"],
        ["@ctl.Shade.stunned", "==", true]
      ],
      "do": [
        { "set": "@ctl.Cell.cx", "to": 3 },
        { "emit": "play-sound", "data": { "sound": "click.wav", "volume": 0.4 } }
      ]
    },
    {
      "id": "pause-menu-key",
      "on": { "event": "input", "filter": { "action": "m", "phase": "pressed" } },
      "if": [
        ["@ctl", "exists"],
        ["@ctl.Shade.stunned", "==", true]
      ],
      "do": [
        { "emit": "play-sound", "data": { "sound": "click.wav", "volume": 0.6 } },
        { "emit": "load-scene", "data": { "scene": "scenes/menu.json" } }
      ]
    },
    {
      "id": "apply-pause",
      "on": { "event": "sync-pause" },
      "if": [
        ["@banner", "exists"],
        ["@hud-hint", "exists"]
      ],
      "do": [
        { "set": "@banner.Text.content", "to": "event.banner" },
        { "set": "@hud-hint.Text.content", "to": "event.hint" }
      ]
    },
    {
      "id": "apply-oil-flash",
      "on": { "event": "sync-oil-flash" },
      "if": [["@hud-oil", "exists"]],
      "do": [
        { "set": "@hud-oil.Text.color", "to": "event.color" }
      ]
    },
    {
      "id": "apply-toast",
      "on": { "event": "sync-toast" },
      "if": [["@hud-toast", "exists"]],
      "do": [
        { "set": "@hud-toast.Text.content", "to": "event.text" }
      ]
    },
    {
      "id": "bgm-victory",
      "on": {
        "event": "scene-loaded",
        "filter": {
          "scene": "scenes/victory.json"
        }
      },
      "do": [
        {
          "emit": "play-music",
          "data": {
            "sound": "bgm-menu.wav",
            "volume": 0.3
          }
        }
      ]
    }
  ]
}