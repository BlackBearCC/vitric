{
  "rules": [
    {
      "id": "board-click",
      "on": {
        "event": "mouse"
      },
      "if": [
        [
          "@ctl",
          "exists"
        ],
        [
          "@ctl.Shade.hp",
          "==",
          0
        ]
      ],
      "do": [
        {
          "set": "@ctl.Position.x",
          "to": "event.x"
        },
        {
          "set": "@ctl.Position.y",
          "to": "event.y"
        },
        {
          "set": "@ctl.Cell.cx",
          "to": 1
        }
      ]
    },
    {
      "id": "select-card-1",
      "on": {
        "event": "mouse",
        "filter": {
          "entity": "slot-1"
        }
      },
      "if": [
        [
          "@ctl",
          "exists"
        ],
        [
          "@ctl.Shade.hp",
          "==",
          0
        ]
      ],
      "do": [
        {
          "set": "@ctl.Cell.cx",
          "to": 11
        },
        {
          "emit": "play-sound",
          "data": {
            "sound": "click.wav",
            "volume": 0.5
          }
        }
      ]
    },
    {
      "id": "select-card-2",
      "on": {
        "event": "mouse",
        "filter": {
          "entity": "slot-2"
        }
      },
      "if": [
        [
          "@ctl",
          "exists"
        ],
        [
          "@ctl.Shade.hp",
          "==",
          0
        ]
      ],
      "do": [
        {
          "set": "@ctl.Cell.cx",
          "to": 12
        },
        {
          "emit": "play-sound",
          "data": {
            "sound": "click.wav",
            "volume": 0.5
          }
        }
      ]
    },
    {
      "id": "select-card-3",
      "on": {
        "event": "mouse",
        "filter": {
          "entity": "slot-3"
        }
      },
      "if": [
        [
          "@ctl",
          "exists"
        ],
        [
          "@ctl.Shade.hp",
          "==",
          0
        ]
      ],
      "do": [
        {
          "set": "@ctl.Cell.cx",
          "to": 13
        },
        {
          "emit": "play-sound",
          "data": {
            "sound": "click.wav",
            "volume": 0.5
          }
        }
      ]
    },
    {
      "id": "select-card-4",
      "on": {
        "event": "mouse",
        "filter": {
          "entity": "slot-4"
        }
      },
      "if": [
        [
          "@ctl",
          "exists"
        ],
        [
          "@ctl.Shade.hp",
          "==",
          0
        ]
      ],
      "do": [
        {
          "set": "@ctl.Cell.cx",
          "to": 14
        },
        {
          "emit": "play-sound",
          "data": {
            "sound": "click.wav",
            "volume": 0.5
          }
        }
      ]
    },
    {
      "id": "end-turn-key",
      "on": {
        "event": "input",
        "filter": {
          "action": "e",
          "phase": "pressed"
        }
      },
      "if": [
        [
          "@ctl",
          "exists"
        ],
        [
          "@ctl.Shade.hp",
          "==",
          0
        ]
      ],
      "do": [
        {
          "set": "@ctl.Cell.cx",
          "to": 2
        },
        {
          "emit": "play-sound",
          "data": {
            "sound": "click.wav",
            "volume": 0.4
          }
        }
      ]
    },
    {
      "id": "apply-hud",
      "on": {
        "event": "sync-hud"
      },
      "do": [
        {
          "set": "@hud-oil.Text.content",
          "to": "event.oil"
        },
        {
          "set": "@hud-hearts.Text.content",
          "to": "event.hearts"
        },
        {
          "set": "@hud-turn.Text.content",
          "to": "event.turn"
        }
      ]
    },
    {
      "id": "apply-banner",
      "on": {
        "event": "sync-hud"
      },
      "if": [
        [
          "@banner",
          "exists"
        ]
      ],
      "do": [
        {
          "set": "@banner.Text.content",
          "to": "event.banner"
        }
      ]
    },
    {
      "id": "apply-hand",
      "on": {
        "event": "sync-hand"
      },
      "do": [
        {
          "set": "@slot-1.Text.content",
          "to": "event.t1"
        },
        {
          "set": "@slot-1.Sprite.color",
          "to": "event.c1"
        },
        {
          "set": "@slot-2.Text.content",
          "to": "event.t2"
        },
        {
          "set": "@slot-2.Sprite.color",
          "to": "event.c2"
        },
        {
          "set": "@slot-3.Text.content",
          "to": "event.t3"
        },
        {
          "set": "@slot-3.Sprite.color",
          "to": "event.c3"
        },
        {
          "set": "@slot-4.Text.content",
          "to": "event.t4"
        },
        {
          "set": "@slot-4.Sprite.color",
          "to": "event.c4"
        }
      ]
    },
    {
      "id": "apply-battle",
      "on": {
        "event": "sync-battle"
      },
      "do": [
        {
          "set": "@progress.Run.phase",
          "to": "event.phase"
        },
        {
          "set": "@progress.Run.turn",
          "to": "event.turn"
        }
      ]
    },
    {
      "id": "advance-progress",
      "on": {
        "event": "node-cleared"
      },
      "if": [
        [
          "event.node",
          ">",
          "@progress.Run.node"
        ]
      ],
      "do": [
        {
          "set": "@progress.Run.node",
          "to": "event.node"
        }
      ]
    },
    {
      "id": "autosave-on-clear",
      "on": {
        "event": "node-cleared"
      },
      "do": [
        {
          "emit": "save-game",
          "data": {
            "slot": "auto"
          }
        }
      ]
    },
    {
      "id": "autosave-on-map",
      "on": {
        "event": "scene-loaded",
        "filter": {
          "scene": "scenes/map.json"
        }
      },
      "if": [
        [
          "@progress",
          "exists"
        ]
      ],
      "do": [
        {
          "emit": "save-game",
          "data": {
            "slot": "auto"
          }
        }
      ]
    },
    {
      "id": "battle-exit-to-map",
      "on": {
        "event": "battle-exit"
      },
      "if": [
        [
          "event.node",
          "<=",
          2
        ]
      ],
      "do": [
        {
          "emit": "load-scene",
          "data": {
            "scene": "scenes/map.json"
          }
        }
      ]
    },
    {
      "id": "battle-exit-to-victory",
      "on": {
        "event": "battle-exit"
      },
      "if": [
        [
          "event.node",
          ">=",
          3
        ]
      ],
      "do": [
        {
          "emit": "run-complete",
          "data": {}
        },
        {
          "emit": "load-scene",
          "data": {
            "scene": "scenes/victory.json"
          }
        }
      ]
    },
    {
      "id": "battle-retreat-to-map",
      "on": {
        "event": "battle-retreat"
      },
      "do": [
        {
          "emit": "load-scene",
          "data": {
            "scene": "scenes/map.json"
          }
        }
      ]
    },
    {
      "id": "menu-new-run",
      "on": {
        "event": "mouse",
        "filter": {
          "entity": "start-btn"
        }
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "click.wav",
            "volume": 0.6
          }
        },
        {
          "emit": "load-scene",
          "data": {
            "scene": "scenes/map.json"
          }
        }
      ]
    },
    {
      "id": "menu-continue",
      "on": {
        "event": "mouse",
        "filter": {
          "entity": "continue-btn"
        }
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "click.wav",
            "volume": 0.6
          }
        },
        {
          "emit": "load-game",
          "data": {
            "slot": "auto"
          }
        }
      ]
    },
    {
      "id": "map-enter-battle-1",
      "on": {
        "event": "mouse",
        "filter": {
          "entity": "node-1"
        }
      },
      "if": [
        [
          "@progress",
