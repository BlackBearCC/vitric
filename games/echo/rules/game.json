          "scene": "scenes/map.json"
        }
      },
      "if": [
        [
          "@progress.Run.node",
          ">=",
          2
        ]
      ],
      "do": [
        {
          "set": "@node-boss.Sprite.color",
          "to": "#e8a44c"
        }
      ]
    },
    {
      "id": "map-tint-node-1-cleared",
      "on": {
        "event": "scene-loaded",
        "filter": {
          "scene": "scenes/map.json"
        }
      },
      "if": [
        [
          "@progress.Run.node",
          ">=",
          1
        ]
      ],
      "do": [
        {
          "set": "@node-1.Sprite.color",
          "to": "#6f6a7a"
        }
      ]
    },
    {
      "id": "map-tint-node-2-cleared",
      "on": {
        "event": "scene-loaded",
        "filter": {
          "scene": "scenes/map.json"
        }
      },
      "if": [
        [
          "@progress.Run.node",
