        }
      ]
    },
    {
      "id": "hit-feedback",
      "on": {
        "event": "player-hit"
      },
      "do": [
        {
          "set": "@camera.Shake.amplitude",
          "to": 0.5
        },
        {
          "emit": "play-sound",
          "data": {
            "sound": "hit.wav",
            "volume": 0.8
          }
        }
      ]
    },
    {
      "id": "shade-died-feedback",
      "on": {
        "event": "shade-died"
      },
      "do": [
        {
          "set": "@camera.Shake.amplitude",
          "to": 0.3
        },
        {
          "emit": "play-sound",
          "data": {
            "sound": "die.wav",
            "volume": 0.7
          }
        },
        {
          "call": "burst",
          "with": {
            "x": "event.x",
            "y": "event.y",
            "n": 10
          }
        }
      ]
    },
    {
      "id": "shade-stunned-sound",
      "on": {
        "event": "shade-stunned"
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "stun.wav",
            "volume": 0.6
          }
        }
      ]
    },
    {
      "id": "shade-acted-sound",
      "on": {
        "event": "shade-acted"
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "hiss.wav",
            "volume": 0.3
          }
        }
      ]
    },
    {
      "id": "card-played-sound",
      "on": {
        "event": "card-played"
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "card.wav",
            "volume": 0.6
          }
        }
      ]
    },
    {
      "id": "lamp-placed-sound",
      "on": {
        "event": "card-played",
        "filter": {
          "name": "lamp"
        }
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "lamp.wav",
            "volume": 0.7
          }
        }
      ]
    },
    {
      "id": "card-rejected-sound",
      "on": {
        "event": "card-rejected"
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "reject.wav",
            "volume": 0.5
          }
        }
      ]
    },
    {
      "id": "lamp-devoured-feedback",
      "on": {
        "event": "lamp-devoured"
      },
      "do": [
        {
          "set": "@camera.Shake.amplitude",
          "to": 0.4
        },
        {
          "emit": "play-sound",
          "data": {
            "sound": "devour.wav",
            "volume": 0.8
          }
        }
      ]
    },
    {
      "id": "battle-won-feedback",
      "on": {
        "event": "battle-won"
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "win.wav",
            "volume": 0.8
          }
        },
        {
          "call": "burst",
          "with": {
            "x": 0,
            "y": 0,
            "n": 24
          }
        }
      ]
    },
    {
      "id": "battle-lost-sound",
      "on": {
        "event": "battle-lost"
      },
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "lose.wav",
            "volume": 0.8
          }
        }
      ]
    },
    {
      "id": "bgm-boot",
      "on": {
        "event": "start"
      },
      "do": [
        {
          "emit": "play-music",
          "data": {
            "sound": "bgm-menu.wav",
            "volume": 0.3
          }
        }
      ]
    },
    {
      "id": "bgm-menu",
      "on": {
