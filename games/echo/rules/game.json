        ]
      ],
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "click.wav",
            "volume": 0.6
          }
        },
        {
          "emit": "load-scene",
          "data": {
            "scene": "scenes/battle-1.json"
          }
        }
      ]
    },
    {
      "id": "map-enter-battle-2",
      "on": {
        "event": "mouse",
        "filter": {
