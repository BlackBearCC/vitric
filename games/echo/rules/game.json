          }
        }
      ]
    },
    {
      "id": "victory-back-to-menu",
      "on": {
        "event": "mouse",
        "filter": {
          "entity": "menu-btn"
        }
      },
      "if": [
        [
          "@progress",
          "exists"
        ]
      ],
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "click.wav",
            "volume": 0.6
          }
        },
        {
          "despawn": "@progress"
        },
        {
          "emit": "load-scene",
          "data": {
            "scene": "scenes/menu.json"
          }
        }
      ]
    },
    {
      "id": "map-tint-node-1-open",
      "on": {
        "event": "scene-loaded",
        "filter": {
          "scene": "scenes/map.json"
        }
      },
      "do": [
        {
          "set": "@node-1.Sprite.color",
          "to": "#e8a44c"
        }
      ]
    },
    {
      "id": "map-tint-node-2-open",
      "on": {
        "event": "scene-loaded",
        "filter": {
