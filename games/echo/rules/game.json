        }
      },
      "if": [
        [
          "@progress",
          "exists"
        ],
        [
          "@progress.Run.node",
          ">=",
          1
        ]
      ],
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "click.wav",
            "volume": 0.6
          }
        },
        {
          "emit": "load-scene",
          "data": {
            "scene": "scenes/battle-2.json"
          }
        }
      ]
    },
    {
      "id": "map-enter-boss",
      "on": {
        "event": "mouse",
        "filter": {
          "entity": "node-boss"
        }
      },
      "if": [
        [
          "@progress",
          "exists"
        ],
        [
          "@progress.Run.node",
          ">=",
          2
        ]
      ],
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "click.wav",
            "volume": 0.6
          }
        },
        {
          "emit": "load-scene",
          "data": {
            "scene": "scenes/boss.json"
          }
        }
      ]
    },
    {
      "id": "victory-back-to-menu",
      "on": {
        "event": "mouse",
        "filter": {
          "entity": "menu-btn"
        }
      },
      "if": [
        [
          "@progress",
          "exists"
        ]
      ],
      "do": [
        {
          "emit": "play-sound",
          "data": {
            "sound": "click.wav",
            "volume": 0.6
          }
        },
        {
          "set": "@progress.Run.node",
          "to": 0
        },
        {
          "set": "@progress.Run.phase",
          "to": "player"
        },
        {
          "set": "@progress.Run.turn",
          "to": 1
        },
        {
          "emit": "load-scene",
          "data": {
            "scene": "scenes/menu.json"
          }
        }
      ]
    },
    {
      "id": "map-tint-node-1-open",
      "on": {
        "event": "scene-loaded",
        "filter": {
          "scene": "scenes/map.json"
        }
      },
      "do": [
        {
          "set": "@node-1.Sprite.color",
          "to": "#e8a44c"
        }
      ]
    },
    {
      "id": "map-tint-node-2-open",
      "on": {
        "event": "scene-loaded",
        "filter": {
