{
  "rules": [
    {
      "id": "build-click",
      "comment": "建造模式下左键点地 → 调 build 脚本(算料/扣料/spawn 结构)。把点击坐标、命中实体名、选中 kind、当前背包全集都传进去——脚本够不到别的实体,只能靠规则喂参数。",
      "on": { "event": "mouse" },
      "if": [ ["@uistate.Mode.value", "==", "build"] ],
      "do": [
        { "call": "build", "with": {
          "x": "event.x", "y": "event.y", "entity": "event.entity", "kind": "@uistate.Build.kind",
          "ore": "@player.Inventory.ore", "wood": "@player.Inventory.wood", "fiber": "@player.Inventory.fiber",
          "seed": "@player.Inventory.seed", "wheat": "@player.Inventory.wheat", "plank": "@player.Inventory.plank",
          "chair": "@player.Inventory.chair", "lamp": "@player.Inventory.lamp"
        } }
      ]
    },

    {
      "id": "craft-plank",
      "on": { "event": "ui-activate", "filter": { "action": "craft-plank" } },
      "do": [ { "call": "craft", "with": {
        "id": "plank",
        "ore": "@player.Inventory.ore", "wood": "@player.Inventory.wood", "fiber": "@player.Inventory.fiber",
        "seed": "@player.Inventory.seed", "wheat": "@player.Inventory.wheat", "plank": "@player.Inventory.plank",
        "chair": "@player.Inventory.chair", "lamp": "@player.Inventory.lamp"
      } } ]
    },
    {
      "id": "craft-chair",
      "on": { "event": "ui-activate", "filter": { "action": "craft-chair" } },
      "do": [ { "call": "craft", "with": {
        "id": "chair",
        "ore": "@player.Inventory.ore", "wood": "@player.Inventory.wood", "fiber": "@player.Inventory.fiber",
        "seed": "@player.Inventory.seed", "wheat": "@player.Inventory.wheat", "plank": "@player.Inventory.plank",
        "chair": "@player.Inventory.chair", "lamp": "@player.Inventory.lamp"
      } } ]
    },
    {
      "id": "craft-lamp",
      "on": { "event": "ui-activate", "filter": { "action": "craft-lamp" } },
      "do": [ { "call": "craft", "with": {
        "id": "lamp",
        "ore": "@player.Inventory.ore", "wood": "@player.Inventory.wood", "fiber": "@player.Inventory.fiber",
        "seed": "@player.Inventory.seed", "wheat": "@player.Inventory.wheat", "plank": "@player.Inventory.plank",
        "chair": "@player.Inventory.chair", "lamp": "@player.Inventory.lamp"
      } } ]
    },

    {
      "id": "inv-apply",
      "comment": "build/craft 脚本算完后 emit inv-set{扣完的绝对值全集},这里写回背包(绝对值=幂等,重放/重复应用一致)。",
      "on": { "event": "inv-set" },
      "do": [
        { "set": "@player.Inventory.ore",   "to": "event.ore" },
        { "set": "@player.Inventory.wood",  "to": "event.wood" },
        { "set": "@player.Inventory.fiber", "to": "event.fiber" },
        { "set": "@player.Inventory.seed",  "to": "event.seed" },
        { "set": "@player.Inventory.wheat", "to": "event.wheat" },
        { "set": "@player.Inventory.plank", "to": "event.plank" },
        { "set": "@player.Inventory.chair", "to": "event.chair" },
        { "set": "@player.Inventory.lamp",  "to": "event.lamp" }
      ]
    },

    {
      "id": "seed-start",
      "comment": "开局给点起步料,让建造/制作/种地都够得着(spec 建议 seed5/wood4/ore4/fiber2)。再加 plank2 让信标(ore2+plank2)和住所(plank2)开局即可造,纵切能一路打到成形。",
      "on": { "event": "start" },
      "do": [
        { "set": "@player.Inventory.seed",  "to": 5 },
        { "set": "@player.Inventory.wood",  "to": 4 },
        { "set": "@player.Inventory.ore",   "to": 4 },
        { "set": "@player.Inventory.fiber", "to": 2 },
        { "set": "@player.Inventory.plank", "to": 2 }
      ]
    }
  ]
}
