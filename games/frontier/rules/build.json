{
  "rules": [
    { "id": "sel-floor",   "on": { "event": "input", "filter": { "action": "1", "phase": "pressed" } }, "do": [ { "set": "@ui.Build.kind", "to": "floor" } ] },
    { "id": "sel-wall",    "on": { "event": "input", "filter": { "action": "2", "phase": "pressed" } }, "do": [ { "set": "@ui.Build.kind", "to": "wall" } ] },
    { "id": "sel-plot",    "on": { "event": "input", "filter": { "action": "3", "phase": "pressed" } }, "do": [ { "set": "@ui.Build.kind", "to": "plot" } ] },
    { "id": "sel-conduit", "on": { "event": "input", "filter": { "action": "4", "phase": "pressed" } }, "do": [ { "set": "@ui.Build.kind", "to": "conduit" } ] },
    { "id": "sel-quarters", "on": { "event": "input", "filter": { "action": "5", "phase": "pressed" } }, "do": [ { "set": "@ui.Build.kind", "to": "quarters" } ] },
    { "id": "sel-extractor", "on": { "event": "input", "filter": { "action": "6", "phase": "pressed" } }, "do": [ { "set": "@ui.Build.kind", "to": "extractor" } ] },

    { "id": "build",  "on": { "event": "mouse" },     "do": [ { "call": "build",  "with": { "x": "event.x", "y": "event.y", "kind": "@ui.Build.kind" } } ] },
    { "id": "remove", "on": { "event": "mouse-alt" }, "do": [ { "call": "remove", "with": { "entity": "event.entity" } } ] }
  ]
}
