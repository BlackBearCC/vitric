{
  "rules": [
    {
      "id": "hud-res",
      "comment": "顶部 HUD 资源段(中):矿/木/纤维/麦。每帧刷 @player。食段单独走 hud_food_lbl(脚本维护 bar 串)。",
      "on": "tick",
      "do": [
        {
          "set": "@hud_res_lbl.UiLabel.content",
          "to": { "format": "矿 {}   木 {}   纤维 {}   麦 {}",
                  "args": [
                    "@player.Inventory.ore",
                    "@player.Inventory.wood",
                    "@player.Inventory.fiber",
                    "@player.Inventory.wheat"
                  ] }
        }
      ]
    },
    {
      "id": "hud-stage",
      "comment": "顶部 HUD 阶段段(右):聚落▸阶段名。每帧刷 @colony。",
      "on": "tick",
      "do": [
        {
          "set": "@hud_stage_lbl.UiLabel.content",
          "to": { "format": "聚落▸{}", "args": ["@colony.Colony.stage"] }
        }
      ]
    },
    {
      "id": "hud-food-bar",
      "comment": "食段(中右):food-bar 系统每帧写 Colony.food_bar(串带 10 格进度条),这里直拉。",
      "on": "tick",
      "do": [
        {
          "set": "@hud_food_lbl.UiLabel.content",
          "to": "@colony.Colony.food_bar"
        }
      ]
    },
    {
      "id": "hud-inv",
      "comment": "背包每格标签:<名> <数量>,每帧刷(读 @player.Inventory)。字号 18 走小字档。",
      "on": "tick",
      "do": [
        { "set": "@inv-ore_lbl.UiLabel.content",   "to": { "format": "矿 {}",  "args": ["@player.Inventory.ore"] } },
        { "set": "@inv-wood_lbl.UiLabel.content",  "to": { "format": "木 {}",  "args": ["@player.Inventory.wood"] } },
        { "set": "@inv-fiber_lbl.UiLabel.content", "to": { "format": "纤 {}",  "args": ["@player.Inventory.fiber"] } },
        { "set": "@inv-seed_lbl.UiLabel.content",  "to": { "format": "种 {}",  "args": ["@player.Inventory.seed"] } },
        { "set": "@inv-wheat_lbl.UiLabel.content", "to": { "format": "麦 {}",  "args": ["@player.Inventory.wheat"] } },
        { "set": "@inv-plank_lbl.UiLabel.content", "to": { "format": "板 {}",  "args": ["@player.Inventory.plank"] } },
        { "set": "@inv-chair_lbl.UiLabel.content", "to": { "format": "椅 {}",  "args": ["@player.Inventory.chair"] } },
        { "set": "@inv-lamp_lbl.UiLabel.content",  "to": { "format": "灯 {}",  "args": ["@player.Inventory.lamp"] } }
      ]
    },
    {
      "id": "hud-flare-bar",
      "comment": "耀斑预警条:flare-bar 系统写 Colony.flare_bar,这里拉到 @flare_lbl。@flare_lbl 实体在 Task 9 场景 polish 里加,届时该规则生效。",
      "on": "tick",
      "do": [
        { "set": "@flare_lbl.UiLabel.content", "to": "@colony.Colony.flare_bar" }
      ]
    },
    {
      "id": "hud-season",
      "comment": "季节段:第 N 年 · season。每帧刷 @colony.Season。",
      "on": "tick",
      "do": [
        { "set": "@season_lbl.UiLabel.content", "to": { "format": "第 {} 年 · {}", "args": ["@colony.Season.year", "@colony.Season.current"] } }
      ]
    },
    {
      "id": "hud-weather",
      "comment": "天气段:天气：weather。每帧刷 @colony.Weather。",
      "on": "tick",
      "do": [
        { "set": "@weather_lbl.UiLabel.content", "to": { "format": "天气：{}", "args": ["@colony.Weather.current"] } }
      ]
    },
    {
      "id": "hud-forecast",
      "comment": "7-day weather forecast bar. forecast-update system writes Forecast.days once per day.",
      "on": "tick",
      "do": [
        { "set": "@forecast_lbl.UiLabel.content", "to": "@colony.Forecast.days" }
      ]
    },
    {
      "id": "hud-techpoint",
      "comment": "科技点 HUD:科技点 N。每帧刷 @player.TechPoint.value。",
      "on": "tick",
      "do": [
        { "set": "@techpoint_lbl.UiLabel.content", "to": { "format": "科技点 {}", "args": ["@player.TechPoint.value"] } }
      ]
    },
    {
      "id": "hud-research-status",
      "comment": "研发状态 HUD:研究中: <name> (<progress>/<total>s)。每帧刷 @colony.Research。",
      "on": "tick",
      "do": [
        { "set": "@research_status_lbl.UiLabel.content", "to": { "format": "研究中: {} ({}/{})", "args": ["@colony.Research.current", "@colony.Research.progress", "@colony.Research.cost_total"] } }
      ]
    },
    {
      "id": "hud-collective-wish-pending",
      "comment": "共识愿望未达成:显示 粮储 NN/50。每帧刷 @colony.Colony.food_i(只要 collective_wish_done==0)。",
      "on": "tick",
      "if": [ ["@colony.Colony.collective_wish_done", "==", 0] ],
      "do": [
        { "set": "@collective_wish_lbl.UiLabel.content", "to": { "format": "共识: 粮储 {}/50 (未达成)", "args": ["@colony.Colony.food_i"] } }
      ]
    },
    {
      "id": "hud-collective-wish-done",
      "comment": "共识愿望已达成:显示 ✓共识达成。collective_wish_done==1 时刷。",
      "on": "tick",
      "if": [ ["@colony.Colony.collective_wish_done", "==", 1] ],
      "do": [
        { "set": "@collective_wish_lbl.UiLabel.content", "to": "✓共识达成: 粮储 50" }
      ]
    },
    {
      "id": "hud-hp",
      "comment": "HP HUD:显示玩家当前 HP/MaxHp。每帧刷 @player.Hp(战斗系统 Task 10)。",
      "on": "tick",
      "do": [
        { "set": "@hp_lbl.UiLabel.content", "to": { "format": "HP {}/{}", "args": ["@player.Hp.value", "@player.Hp.max"] } }
      ]
    }
  ]
}
