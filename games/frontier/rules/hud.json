{
  "rules": [
    {
      "id": "hud-res",
      "on": "tick",
      "do": [
        {
          "set": "@hud_res.Text.content",
          "to": { "format": "氧 {}   电 {}   食 {}   人手 {}", "args": ["@colony.Colony.o2_i", "@colony.Colony.pow_i", "@colony.Colony.food_i", "@colony.Colony.pop"] }
        }
      ]
    }
  ]
}
