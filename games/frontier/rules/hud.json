{
  "rules": [
    {
      "id": "hud-res",
      "comment": "顶部资源条:阶段 + 氧/电/食/水/人手 + 第几天。每帧刷(读 @colony 的取整字段)。",
      "on": "tick",
      "do": [
        {
          "set": "@hud_res.UiLabel.content",
          "to": { "format": "【{}】 第{}天 · {}  氧 {}  电 {}  食 {}  水 {}  人手 {}",
                  "args": [
                    "@colony.Colony.stage",
                    "@colony.Clock.day",
                    "@colony.Clock.tod",
                    "@colony.Colony.o2_i",
                    "@colony.Colony.pow_i",
                    "@colony.Colony.food_i",
                    "@colony.Colony.water_i",
                    "@colony.Colony.pop"
                  ] }
        }
      ]
    },

    {
      "id": "hud-inv",
      "comment": "背包每格标签:<名> <数量>,每帧刷(读 @player.Inventory)。",
      "on": "tick",
      "do": [
        { "set": "@inv-ore_lbl.UiLabel.content",   "to": { "format": "矿石 {}", "args": ["@player.Inventory.ore"] } },
        { "set": "@inv-wood_lbl.UiLabel.content",  "to": { "format": "木料 {}", "args": ["@player.Inventory.wood"] } },
        { "set": "@inv-fiber_lbl.UiLabel.content", "to": { "format": "纤维 {}", "args": ["@player.Inventory.fiber"] } },
        { "set": "@inv-seed_lbl.UiLabel.content",  "to": { "format": "麦种 {}", "args": ["@player.Inventory.seed"] } },
        { "set": "@inv-wheat_lbl.UiLabel.content", "to": { "format": "麦子 {}", "args": ["@player.Inventory.wheat"] } },
        { "set": "@inv-plank_lbl.UiLabel.content", "to": { "format": "木板 {}", "args": ["@player.Inventory.plank"] } },
        { "set": "@inv-chair_lbl.UiLabel.content", "to": { "format": "椅子 {}", "args": ["@player.Inventory.chair"] } },
        { "set": "@inv-lamp_lbl.UiLabel.content",  "to": { "format": "灯 {}",   "args": ["@player.Inventory.lamp"] } }
      ]
    }
  ]
}
