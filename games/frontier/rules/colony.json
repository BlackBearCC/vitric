{
  "rules": [
    {
      "id": "apply-rates",
      "comment": "tally 速率 + struct_count + monument 标记 落进 @colony.Colony。",
      "on": { "event": "tally" },
      "do": [
        { "set": "@colony.Colony.pow_rate", "to": "event.pow" },
        { "set": "@colony.Colony.food_rate", "to": "event.food" },
        { "set": "@colony.Colony.o2_rate", "to": "event.o2" },
        { "set": "@colony.Colony.water_rate", "to": "event.water" },
        { "set": "@colony.Colony.struct_count", "to": "event.total" }
      ]
    },
    {
      "id": "apply-monument",
      "comment": "丰碑存在 → @colony.Colony.monument_built = 1(供 quest-step7 / stage 系统读)。",
      "on": { "event": "monument-present" },
      "do": [
        { "set": "@colony.Colony.monument_built", "to": "event.count" }
      ]
    },
    {
      "id": "apply-census",
      "comment": "census-tick{pop} → @colony.Colony.pop。",
      "on": { "event": "census-tick" },
      "do": [
        { "set": "@colony.Colony.pop", "to": "event.pop" }
      ]
    }
  ]
}
