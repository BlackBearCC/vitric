{
  "rules": [
    { "id": "move-right-on",  "on": { "event": "input", "filter": { "action": "right", "phase": "pressed" } },  "do": [ { "set": "@player.Velocity.x", "to": 4 } ] },
    { "id": "move-right-off", "on": { "event": "input", "filter": { "action": "right", "phase": "released" } }, "do": [ { "set": "@player.Velocity.x", "to": 0 } ] },
    { "id": "move-left-on",   "on": { "event": "input", "filter": { "action": "left", "phase": "pressed" } },   "do": [ { "set": "@player.Velocity.x", "to": -4 } ] },
    { "id": "move-left-off",  "on": { "event": "input", "filter": { "action": "left", "phase": "released" } },  "do": [ { "set": "@player.Velocity.x", "to": 0 } ] },
    { "id": "move-up-on",     "on": { "event": "input", "filter": { "action": "up", "phase": "pressed" } },     "do": [ { "set": "@player.Velocity.y", "to": 4 } ] },
    { "id": "move-up-off",    "on": { "event": "input", "filter": { "action": "up", "phase": "released" } },    "do": [ { "set": "@player.Velocity.y", "to": 0 } ] },
    { "id": "move-down-on",   "on": { "event": "input", "filter": { "action": "down", "phase": "pressed" } },   "do": [ { "set": "@player.Velocity.y", "to": -4 } ] },
    { "id": "move-down-off",  "on": { "event": "input", "filter": { "action": "down", "phase": "released" } },  "do": [ { "set": "@player.Velocity.y", "to": 0 } ] }
  ]
}
