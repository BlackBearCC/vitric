{
  "rules": [
    {
      "id": "drifter-talk",
      "comment": "按 t 键且玩家靠近漂泊旅人(距离<4)时,发 LLM 对话。旅人人设传进 fn 当 prompt。",
      "on": { "event": "input", "filter": { "action": "t", "phase": "pressed" } },
      "do": [{ "call": "talkNearby", "with": {
        "px": "@player.Position.x", "py": "@player.Position.y",
        "dx": "@drifter.Position.x", "dy": "@drifter.Position.y",
        "pname": "@drifter.Persona.name", "parch": "@drifter.Persona.archetype",
        "ptraits": "@drifter.Persona.traits", "pspeech": "@drifter.Persona.speech",
        "entity": "drifter"
      } }]
    },

    {
      "id": "companion-talk",
      "comment": "旅人已入住后,T 键对话转给 Pip。",
      "on": { "event": "input", "filter": { "action": "t", "phase": "pressed" } },
      "do": [{ "call": "talkNearby", "with": {
        "px": "@player.Position.x", "py": "@player.Position.y",
        "dx": "@companion.Position.x", "dy": "@companion.Position.y",
        "pname": "@companion.Persona.name", "parch": "@companion.Persona.archetype",
        "ptraits": "@companion.Persona.traits", "pspeech": "@companion.Persona.speech",
        "entity": "companion"
      } }]
    },

    {
      "id": "drifter-invite",
      "comment": "按 i 键且靠近旅人时,发邀请。",
      "on": { "event": "input", "filter": { "action": "i", "phase": "pressed" } },
      "do": [{ "call": "inviteNearby", "with": {
        "px": "@player.Position.x", "py": "@player.Position.y",
        "dx": "@drifter.Position.x", "dy": "@drifter.Position.y",
        "pname": "@drifter.Persona.name", "parch": "@drifter.Persona.archetype",
        "ptraits": "@drifter.Persona.traits", "pspeech": "@drifter.Persona.speech"
      } }]
    },

    {
      "id": "llm-reply-router",
      "comment": "预置分发:所有 llm-reply 事件转进 __onReply,回调 fn 名从 id 前段解析。",
      "on": { "event": "llm-reply" },
      "do": [{ "call": "__onReply", "with": { "id": "event.id", "text": "event.text" } }]
    },
    {
      "id": "llm-error-handler",
      "comment": "LLM 出错时给默认回复(测试/离线环境)。",
      "on": { "event": "llm-error" },
      "do": [{ "call": "__onReply", "with": { "id": "event.id", "text": "（旅人沉默片刻,点了点头）" } }]
    },

    {
      "id": "companion-invite-process",
      "comment": "邀请 → despawn 旧旅人 + 在家园 spawn 伙伴 + 任务推进。",
      "on": { "event": "companion-invited" },
      "do": [
        { "despawn": "@drifter" },
        { "call": "spawnCompanion", "with": { "persona": { "name": "event.name", "archetype": "event.archetype", "traits": "event.traits", "speech": "event.speech" } } }
      ]
    },

    {
      "id": "companion-movein-quest",
      "comment": "伙伴入住 → 如果 quest step==3,推进到 step 4。",
      "on": { "event": "companion-moved-in" },
      "if": [ ["@quest.QuestLog.step", "==", 3] ],
      "do": [
        { "set": "@quest.QuestLog.step", "to": 4 },
        { "emit": "quest-done", "data": { "id": "companion" } }
      ]
    },

    {
      "id": "companion-leave",
      "comment": "伙伴离开 → despawn @companion (如果还在就清掉)。",
      "on": { "event": "companion-left" },
      "do": [
        { "despawn": "@companion" }
      ]
    }
  ]
}
