{
  "rules": [
    {
      "id": "drifter-talk",
      "comment": "按 t 键且玩家靠近最近旅人(距离<4)时,发 LLM 对话。pid 给 onTalkReply 算 +affinity 用。",
      "on": { "event": "input", "filter": { "action": "t", "phase": "pressed" } },
      "if": [["@colony.Colony.target_drifter", "!=", ""]],
      "do": [{ "call": "talkNearby", "with": {
        "px": "@colony.Colony.player_x", "py": "@colony.Colony.player_y",
        "dx": "@colony.Colony.target_drifter_x", "dy": "@colony.Colony.target_drifter_y",
        "pid": "@colony.Colony.target_drifter",
        "pname": "@colony.Colony.target_drifter_name", "parch": "@colony.Colony.target_drifter_archetype",
        "ptraits": "@colony.Colony.target_drifter_traits", "pspeech": "@colony.Colony.target_drifter_speech"
      } }]
    },

    {
      "id": "companion-talk",
      "comment": "按 t 键,若旅人不靠近但伙伴靠近(<4),对话转给伙伴。pid 给 onTalkReply 算 +affinity 用。",
      "on": { "event": "input", "filter": { "action": "t", "phase": "pressed" } },
      "if": [
        ["@colony.Colony.target_drifter", "==", ""],
        ["@colony.Colony.target_companion", "!=", ""]
      ],
      "do": [{ "call": "talkNearby", "with": {
        "px": "@colony.Colony.player_x", "py": "@colony.Colony.player_y",
        "dx": "@colony.Colony.target_companion_x", "dy": "@colony.Colony.target_companion_y",
        "pid": "@colony.Colony.target_companion",
        "pname": "@colony.Colony.target_companion_name", "parch": "@colony.Colony.target_companion_archetype",
        "ptraits": "@colony.Colony.target_companion_traits", "pspeech": "@colony.Colony.target_companion_speech"
      } }]
    },

    {
      "id": "companion-gift",
      "comment": "按 g 键且最近伙伴在范围内,送一件背包物品给他/她 +affinity(命中偏好 +12,普通 +3)。",
      "on": { "event": "input", "filter": { "action": "g", "phase": "pressed" } },
      "if": [["@colony.Colony.target_companion", "!=", ""]],
      "do": [{ "call": "giveGiftNearby", "with": {
        "px": "@colony.Colony.player_x", "py": "@colony.Colony.player_y",
        "dx": "@colony.Colony.target_companion_x", "dy": "@colony.Colony.target_companion_y",
        "pid": "@colony.Colony.target_companion",
        "ppreferred": "@colony.Colony.target_companion_preferred",
        "ore": "@player.Inventory.ore",   "wood": "@player.Inventory.wood",
        "fiber": "@player.Inventory.fiber", "seed": "@player.Inventory.seed",
        "wheat": "@player.Inventory.wheat", "plank": "@player.Inventory.plank",
        "chair": "@player.Inventory.chair", "lamp": "@player.Inventory.lamp"
      } }]
    },

    {
      "id": "drifter-invite",
      "comment": "按 i 键且最近旅人在范围内,发邀请事件,带 drifter_id 句柄。",
      "on": { "event": "input", "filter": { "action": "i", "phase": "pressed" } },
      "if": [["@colony.Colony.target_drifter", "!=", ""]],
      "do": [{ "call": "inviteAnyNearby", "with": {
        "px": "@colony.Colony.player_x", "py": "@colony.Colony.player_y",
        "dx": "@colony.Colony.target_drifter_x", "dy": "@colony.Colony.target_drifter_y",
        "drifter_id": "@colony.Colony.target_drifter",
        "pname": "@colony.Colony.target_drifter_name", "parch": "@colony.Colony.target_drifter_archetype",
        "ptraits": "@colony.Colony.target_drifter_traits", "pspeech": "@colony.Colony.target_drifter_speech"
      } }]
    },

    {
      "id": "llm-reply-router",
      "comment": "预置分发:所有 llm-reply 事件转进 __onReply,回调 fn 名从 id 前段解析。",
      "on": { "event": "llm-reply" },
      "do": [{ "call": "__onReply", "with": { "id": "event.id", "text": "event.text" } }]
    },
    {
      "id": "llm-error-handler",
      "comment": "LLM 出错时给默认回复(测试/离线环境)。",
      "on": { "event": "llm-error" },
      "do": [{ "call": "__onReply", "with": { "id": "event.id", "text": "（旅人沉默片刻,点了点头）" } }]
    },

    {
      "id": "companion-invite-process",
      "comment": "邀请 → consumeDrifter(despawn by id + spawn companion + emit moved-in)。",
      "on": { "event": "companion-invited" },
      "do": [
        { "call": "consumeDrifter", "with": {
          "drifter_id": "event.drifter_id",
          "name": "event.name",
          "archetype": "event.archetype",
          "traits": "event.traits",
          "speech": "event.speech"
        } }
      ]
    },

    {
      "id": "companion-movein-counter",
      "comment": "每邀请一位伙伴入住,@colony.Colony.drifters_invited++(HUD 可见)。",
      "on": { "event": "companion-moved-in" },
      "do": [
        { "add": "@colony.Colony.drifters_invited", "by": 1 }
      ]
    },

    {
      "id": "drifter-cadence",
      "comment": "每隔一个游戏日 spawn 一个新旅人(最多 4 个,且场上没人时才 spawn)。",
      "on": { "event": "day-start" },
      "if": [
        ["event.day", ">=", "@colony.Colony.next_drifter_day"],
        ["@colony.Colony.drifters_spawned", "<", 4],
        ["@colony.Colony.target_drifter", "==", ""]
      ],
      "do": [
        { "call": "spawnNewDrifter", "with": {
          "idx": "@colony.Colony.drifters_spawned",
          "arrival_day": "event.day"
        } },
        { "add": "@colony.Colony.drifters_spawned", "by": 1 },
        { "add": "@colony.Colony.next_drifter_day", "by": 2 }
      ]
    },

    {
      "id": "companion-leave",
      "comment": "伙伴离开:companion-need 已自己 despawn,这里只发个事件让 HUD 显示。",
      "on": { "event": "companion-left" },
      "do": [
        { "emit": "companion-departed", "data": { "name": "event.name" } }
      ]
    }
  ]
}