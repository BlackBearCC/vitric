{
  "rules": [
    {
      "id": "quest-step1-done",
      "comment": "step1 修信标:造出 beacon → step=2。守卫 step==1。",
      "on": { "event": "built", "filter": { "kind": "beacon" } },
      "if": [ ["@quest.QuestLog.step", "==", 1] ],
      "do": [
        { "set": "@quest.QuestLog.step", "to": 2 },
        { "emit": "quest-done", "data": { "id": "beacon" } }
      ]
    },
    {
      "id": "quest-step2-done",
      "comment": "step2 种出第一茬:首次收麦 → step=3。守卫 step==2。",
      "on": { "event": "harvested", "filter": { "id": "wheat" } },
      "if": [ ["@quest.QuestLog.step", "==", 2] ],
      "do": [
        { "set": "@quest.QuestLog.step", "to": 3 },
        { "emit": "quest-done", "data": { "id": "wheat" } }
      ]
    },
    {
      "id": "quest-step3-done",
      "comment": "step3 请第一个伙伴:companion-moved-in → step=4。守卫 step==3。",
      "on": { "event": "companion-moved-in" },
      "if": [ ["@quest.QuestLog.step", "==", 3] ],
      "do": [
        { "set": "@quest.QuestLog.step", "to": 4 },
        { "emit": "quest-done", "data": { "id": "first-companion" } }
      ]
    },
    {
      "id": "quest-step4-done",
      "comment": "step4 立足:stage 已经是「立足」(stage 系统在 day≥3 且 结构≥3 时切)→ step=5。",
      "on": "tick",
      "if": [
        ["@quest.QuestLog.step", "==", 4],
        ["@colony.Colony.stage", "==", "立足"]
      ],
      "do": [
        { "set": "@quest.QuestLog.step", "to": 5 },
        { "emit": "quest-done", "data": { "id": "立足" } }
      ]
    },
    {
      "id": "quest-step5-done",
      "comment": "step5 温饱:day≥4 且 小麦存量≥5 → step=6。守卫 step==5 + day-floor + inventory 闸门。",
      "on": "tick",
      "if": [
        ["@quest.QuestLog.step", "==", 5],
        ["@colony.Colony.day", ">=", 4],
        ["@player.Inventory.wheat", ">=", 5]
      ],
      "do": [
        { "set": "@quest.QuestLog.step", "to": 6 },
        { "emit": "quest-done", "data": { "id": "温饱" } }
      ]
    },
    {
      "id": "quest-step6-done",
      "comment": "step6 成群:day≥5 且 人手≥3 → step=7。守卫 step==6 + day-floor + census 闸门。",
      "on": "tick",
      "if": [
        ["@quest.QuestLog.step", "==", 6],
        ["@colony.Colony.day", ">=", 5],
        ["@colony.Colony.pop", ">=", 3]
      ],
      "do": [
        { "set": "@quest.QuestLog.step", "to": 7 },
        { "emit": "quest-done", "data": { "id": "成群" } }
      ]
    },
    {
      "id": "monument-built",
      "comment": "step7 通路条件:monument 一立 → 标 @colony.Colony.monument_built=1。",
      "on": { "event": "built", "filter": { "kind": "monument" } },
      "do": [
        { "set": "@colony.Colony.monument_built", "to": 1 }
      ]
    },
    {
      "id": "game-won",
      "comment": "step7 → day≥6(走 stage「兴旺」闸门)+ 丰碑已立 → settlement-thrived → game-won。",
      "on": "tick",
      "if": [
        ["@quest.QuestLog.step", "==", 7],
        ["@colony.Colony.day", ">=", 6],
        ["@colony.Colony.monument_built", ">=", 1]
      ],
      "do": [
        { "emit": "settlement-thrived", "data": {} },
        { "set": "@quest.QuestLog.step", "to": 8 },
        { "emit": "game-won", "data": {} }
      ]
    },

    {
      "id": "quest-banner-1",
      "comment": "任务栏文案每帧刷。",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 1] ],
      "do": [ { "set": "@quest_banner_lbl.UiLabel.content", "to": "目标:修复信标 — 切建造(q),选信标(6),点地放下" } ]
    },
    {
      "id": "quest-banner-2",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 2] ],
      "do": [ { "set": "@quest_banner_lbl.UiLabel.content", "to": "目标:种出第一茬 — 建种植台,种麦,等熟收" } ]
    },
    {
      "id": "quest-banner-3",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 3] ],
      "do": [ { "set": "@quest_banner_lbl.UiLabel.content", "to": "目标:请第一个伙伴 — 走向野外,靠近后按 I 邀请" } ]
    },
    {
      "id": "quest-banner-4",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 4] ],
      "do": [ { "set": "@quest_banner_lbl.UiLabel.content", "to": "目标:立足脚跟 — 等到第 3 天,建 3 座以上结构" } ]
    },
    {
      "id": "quest-banner-5",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 5] ],
      "do": [ { "set": "@quest_banner_lbl.UiLabel.content", "to": "目标:食物富足 — 攒 5 麦子(收几茬即可),等过第 4 天" } ]
    },
    {
      "id": "quest-banner-6",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 6] ],
      "do": [ { "set": "@quest_banner_lbl.UiLabel.content", "to": "目标:多人聚居 — 等过第 5 天,把第 2、3 个伙伴请回家" } ]
    },
    {
      "id": "quest-banner-7",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 7] ],
      "do": [ { "set": "@quest_banner_lbl.UiLabel.content", "to": "目标:建造丰碑 — 等过第 6 天,攒 ore×4+plank×4+lamp×2+wheat×4 立丰碑" } ]
    },
    {
      "id": "quest-banner-8",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 8] ],
      "do": [ { "set": "@quest_banner_lbl.UiLabel.content", "to": "聚落兴旺!通关!" } ]
    }
  ]
}
