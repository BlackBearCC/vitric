{
  "rules": [
    {
      "id": "quest-step1-done",
      "comment": "step1 修信标:造出 beacon → step=2。守卫 step==1。",
      "on": { "event": "built", "filter": { "kind": "beacon" } },
      "if": [ ["@quest.QuestLog.step", "==", 1] ],
      "do": [
        { "set": "@quest.QuestLog.step", "to": 2 },
        { "emit": "quest-done", "data": { "id": "beacon" } }
      ]
    },
    {
      "id": "quest-step2-done",
      "comment": "step2 种出第一茬:首次收麦 → step=3。守卫 step==2。",
      "on": { "event": "harvested", "filter": { "id": "wheat" } },
      "if": [ ["@quest.QuestLog.step", "==", 2] ],
      "do": [
        { "set": "@quest.QuestLog.step", "to": 3 },
        { "emit": "quest-done", "data": { "id": "wheat" } }
      ]
    },
    {
      "id": "quest-step3-done",
      "comment": "step3 请第一个伙伴:wish-fulfilled + 第一个伙伴(companion)好感>=60 -> step=4.",
      "on": { "event": "wish-fulfilled" },
      "if": [
        ["@quest.QuestLog.step", "==", 3],
        ["@companion.Need.affinity", ">=", 60]
      ],
      "do": [
        { "set": "@quest.QuestLog.step", "to": 4 },
        { "emit": "quest-done", "data": { "id": "first-companion" } }
      ]
    },
    {
      "id": "quest-step4-done",
      "comment": "step4 立足:stage 已经是「立足」(stage 系统在 day≥3 且 结构≥3 时切)→ step=5。",
      "on": "tick",
      "if": [
        ["@quest.QuestLog.step", "==", 4],
        ["@colony.Colony.stage", "==", "立足"]
      ],
      "do": [
        { "set": "@quest.QuestLog.step", "to": 5 },
        { "emit": "quest-done", "data": { "id": "立足" } }
      ]
    },
    {
      "id": "quest-step5-done",
      "comment": "step5 温饱:day≥12 (春末) 且 小麦存量≥5 → step=6。守卫 step==5 + day-floor + inventory 闸门。",
      "on": "tick",
      "if": [
        ["@quest.QuestLog.step", "==", 5],
        ["@colony.Colony.day", ">=", 12],
        ["@player.Inventory.wheat", ">=", 5]
      ],
      "do": [
        { "set": "@quest.QuestLog.step", "to": 6 },
        { "emit": "quest-done", "data": { "id": "温饱" } }
      ]
    },
    {
      "id": "quest-step6-done",
      "comment": "step6 成群:day>=24 (夏末) + pop>=3 + 累计心愿达成>=2 -> step=7.",
      "on": "tick",
      "if": [
        ["@quest.QuestLog.step", "==", 6],
        ["@colony.Colony.day", ">=", 24],
        ["@colony.Colony.pop", ">=", 3],
        ["@colony.Colony.companion_wish_count", ">=", 2]
      ],
      "do": [
        { "set": "@quest.QuestLog.step", "to": 7 },
        { "emit": "quest-done", "data": { "id": "成群" } }
      ]
    },
    {
      "id": "monument-built",
      "comment": "step7 通路条件:monument 一立 → 标 @colony.Colony.monument_built=1。",
      "on": { "event": "built", "filter": { "kind": "monument" } },
      "do": [
        { "set": "@colony.Colony.monument_built", "to": 1 }
      ]
    },
    {
      "id": "settlement-founded",
      "comment": "step7 -> stage==兴旺 (day>=96 + all T2 techs + monument + allied faction) -> settlement-founded. Sandbox continues.",
      "on": "tick",
      "if": [
        ["@quest.QuestLog.step", "==", 7],
        ["@colony.Colony.stage", "==", "兴旺"]
      ],
      "do": [
        { "emit": "settlement-founded", "data": {} },
        { "set": "@quest.QuestLog.step", "to": 8 }
      ]
    },

    {
      "id": "quest-banner-1",
      "comment": "任务卡(右上)两行:目标名 + 一句怎么做。每帧刷。",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 1] ],
      "do": [
        { "set": "@quest_title_lbl.UiLabel.content", "to": "修复信标" },
        { "set": "@quest_sub_lbl.UiLabel.content",   "to": "切建造(q) → 选信标(6) → 点地放下" }
      ]
    },
    {
      "id": "quest-banner-2",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 2] ],
      "do": [
        { "set": "@quest_title_lbl.UiLabel.content", "to": "种出第一茬" },
        { "set": "@quest_sub_lbl.UiLabel.content",   "to": "建种植台 → 撒麦种 → 等熟收" }
      ]
    },
    {
      "id": "quest-banner-3",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 3] ],
      "do": [
        { "set": "@quest_title_lbl.UiLabel.content", "to": "请第一位伙伴" },
        { "set": "@quest_sub_lbl.UiLabel.content",   "to": "走向野外,靠近旅人后按 I 邀请" }
      ]
    },
    {
      "id": "quest-banner-4",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 4] ],
      "do": [
        { "set": "@quest_title_lbl.UiLabel.content", "to": "立足脚跟" },
        { "set": "@quest_sub_lbl.UiLabel.content",   "to": "等到第 12 天(春末),研究 survival_t1 + 凑齐 5 座结构" }
      ]
    },
    {
      "id": "quest-banner-5",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 5] ],
      "do": [
        { "set": "@quest_title_lbl.UiLabel.content", "to": "食物富足" },
        { "set": "@quest_sub_lbl.UiLabel.content",   "to": "攒 5 麦子,等过第 12 天(春末)" }
      ]
    },
    {
      "id": "quest-banner-6",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 6] ],
      "do": [
        { "set": "@quest_title_lbl.UiLabel.content", "to": "多人聚居" },
        { "set": "@quest_sub_lbl.UiLabel.content",   "to": "等过第 24 天(夏末),把第 2、3 个伙伴请回家" }
      ]
    },
    {
      "id": "quest-banner-7",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 7] ],
      "do": [
        { "set": "@quest_title_lbl.UiLabel.content", "to": "建造丰碑" },
        { "set": "@quest_sub_lbl.UiLabel.content",   "to": "等过第 96 天(两年末),研究全部 T2 科技 + 立丰碑 + 任一派系结盟" }
      ]
    },
    {
      "id": "quest-banner-8",
      "on": "tick",
      "if": [ ["@quest.QuestLog.step", "==", 8] ],
      "do": [
        { "set": "@quest_title_lbl.UiLabel.content", "to": "自由探索中" },
        { "set": "@quest_sub_lbl.UiLabel.content",   "to": "定居点已建立,四个循环自驱,继续你的故事" }
      ]
    }
  ]
}
