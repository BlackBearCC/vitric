{
  "rules": [
    {
      "id": "spend",
      "on": { "event": "input", "filter": { "action": "spend", "phase": "pressed" } },
      "if": [
        ["@base.Resources.fuel", ">", 0]
      ],
      "do": [
        { "add": "@base.Resources.fuel", "by": -1 }
      ]
    },
    {
      "id": "go-bankrupt",
      "on": { "event": "input", "filter": { "action": "spend", "phase": "pressed" } },
      "if": [
        ["@base.Resources.fuel", "==", 0],
        ["@base.State.bankrupt", "==", false]
      ],
      "do": [
        { "set": "@base.State.bankrupt", "to": true }
      ]
    }
  ]
}
