       if (!components || typeof components !== "object") {
         throw new Error("ctx.spawn: 第一个参数必须是组件对象，如 {Position: {x:0,y:0}}");
       }
       ops.push({ op: "spawn", components, name: name === undefined ? null : name });
     },
